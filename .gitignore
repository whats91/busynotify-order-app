# File Context:
# Purpose: Defines files and directories excluded from Git tracking.
# Primary Functionality: Prevents local, generated, or secret files from being committed into version control.
# Interlinked With: No direct internal imports; primarily used by framework or toolchain entry points.
# Role: shared project asset.
# Dependencies
node_modules/
.pnp
.pnp.js

# Build / Next
.next/
out/
build/
dist/

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
logs/

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp
*.swo

# Prisma
prisma/migrations/**/migration_lock.toml

# Database files (don't commit local DBs)
*.db
*.sqlite
*.sqlite-shm
*.sqlite-wal
